# AI Anime Generator Environment Configuration
# Copy this file to .env and fill in your values

# ============================================================
# 后端选择 (Backend Selection)
# ============================================================
# 可选值: aistudio (默认) 或 vertex
# Options: aistudio (default) or vertex
GEMINI_BACKEND=aistudio

# ============================================================
# AI Studio 配置 (当 GEMINI_BACKEND=aistudio 时使用)
# ============================================================
# 从 https://aistudio.google.com/apikey 获取 API 密钥
GEMINI_API_KEY=your-gemini-api-key-here

# ============================================================
# Claude Agent SDK 配置
# ============================================================
# 从 https://console.anthropic.com/ 获取 API 密钥
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Assistant 开关（1=启用 SDK，0=仅使用本地桥接）
ASSISTANT_USE_CLAUDE_SDK=1
# Skills 来源（逗号分隔，默认 user,project）
ASSISTANT_SETTING_SOURCES=user,project
# 可选：通过代理/网关自定义 Claude API Base URL
# ANTHROPIC_BASE_URL=https://your-proxy.example.com
# 当使用代理时，将 ANTHROPIC_API_KEY 设为代理的鉴权 token
# 可选：指定 Claude Code CLI 路径（Windows 常用于指定 claude.cmd）
# ASSISTANT_CLAUDE_CLI_PATH=C:\\Users\\your-user\\AppData\\Roaming\\npm\\claude.cmd

# ============================================================
# Vertex AI 配置 (当 GEMINI_BACKEND=vertex 时使用)
# ============================================================
# 将服务账号 JSON 凭证文件放入 vertex_keys/ 目录即可
# 系统会自动读取凭证并从中提取项目 ID
# 无需设置 VERTEX_API_KEY

# GCS Bucket 名称（用于视频延长功能的输出存储）
# Vertex AI 延长视频时需要 GCS 存储，格式: bucket-name（不含 gs:// 前缀）
VERTEX_GCS_BUCKET=your-gcs-bucket-name

# ============================================================
# 速率限制配置 (Rate Limiting Configuration)
# ============================================================
# 图片生成每分钟请求数限制 (默认: 15)
GEMINI_IMAGE_RPM=15
# 视频生成每分钟请求数限制 (默认: 10)
GEMINI_VIDEO_RPM=10
# 两次请求之间的最小间隔（秒）(默认: 3.1)
GEMINI_REQUEST_GAP=3.1

# ============================================================
# 性能配置 (Performance Configuration)
# ============================================================
# 分镜生成时的最大并发线程数 (默认: 3)
STORYBOARD_MAX_WORKERS=3
# 视频生成时的最大并发线程数 (默认: 2)
VIDEO_MAX_WORKERS=2

# ============================================================
# 认证配置 (Authentication)
# ============================================================
# 登录用户名（默认: admin）
AUTH_USERNAME=admin
# 登录密码（留空则首次启动时自动生成并回写到此文件）
AUTH_PASSWORD=
# JWT 签名密钥（留空则自动生成，但重启后 token 失效需重新登录）
AUTH_TOKEN_SECRET=
